{
  "category": "mdm/commands",
  "name": "certificate.list",
  "title": "Certificate List Command",
  "description": "Get a list of installed certificates on a device.",
  "payload": {
    "requesttype": "CertificateList",
    "supportedOS": {
      "iOS": {
        "introduced": "4.0",
        "accessrights": "AllowInspection"
      },
      "macOS": {
        "introduced": "10.7",
        "accessrights": "AllowInspection"
      },
      "tvOS": {
        "introduced": "9.0",
        "accessrights": "AllowInspection"
      },
      "visionOS": {
        "introduced": "1.1",
        "accessrights": "AllowInspection"
      },
      "watchOS": {
        "introduced": "10.0",
        "accessrights": "AllowInspection"
      }
    }
  },
  "payloadkeys": [
    {
      "key": "ManagedOnly",
      "type": "\u003cboolean\u003e",
      "presence": "optional",
      "default": false,
      "content": "If `true`, only include certificates that MDM installed or that are in the same profile as the MDM payload. User-enrolled devices ignore this value and always only include managed certificates. This value is available in iOS 13 and later, macOS 10.15 and later, and tvOS 13 and later.",
      "supportedOS": {
        "iOS": {
          "introduced": "13.0"
        },
        "macOS": {
          "introduced": "10.15"
        },
        "tvOS": {
          "introduced": "13.0"
        }
      }
    }
  ],
  "responsekeys": [
    {
      "key": "CertificateList",
      "type": "\u003carray\u003e",
      "presence": "required",
      "content": "An array of certificate list items that describes each certificate.",
      "subkeys": [
        {
          "key": "CertificateListItem",
          "type": "\u003cdictionary\u003e",
          "content": "A dictionary that contains information about a certificate list item.",
          "subkeys": [
            {
              "key": "CommonName",
              "type": "\u003cstring\u003e",
              "presence": "required",
              "content": "The certificate's common name."
            },
            {
              "key": "IsIdentity",
              "type": "\u003cboolean\u003e",
              "presence": "required",
              "content": "If `true`, this is an identity certificate."
            },
            {
              "key": "Data",
              "type": "\u003cdata\u003e",
              "presence": "required",
              "content": "The certificate in DER-encoded X.509 format."
            }
          ]
        }
      ]
    }
  ]
}
