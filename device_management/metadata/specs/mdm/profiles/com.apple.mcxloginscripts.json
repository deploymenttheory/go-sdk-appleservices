      },
      "tvOS": {
        "introduced": "n/a"
      },
      "visionOS": {
        "introduced": "n/a"
      },
      "watchOS": {
        "introduced": "n/a"
      }
    }
  },
  "payloadkeys": [
    {
      "key": "loginscripts",
      "type": "\u003carray\u003e",
