{
  "category": "mdm/profiles",
  "name": "com.apple.mcxloginscripts",
  "title": "Login Window: Scripts",
  "description": "The payload that configures scripts to run at login and logout.",
  "payload": {
    "payloadtype": "com.apple.mcxloginscripts",
    "content": "Login and logout managed script handling",
    "supportedOS": {
