          "type": "\u003cinteger\u003e",
          "presence": "optional",
          "rangelist": [
            0,
            1
          ],
          "content": "If `true`, enables \"Wake for network access.\""
        },
        {
          "key": "Wake On Modem Ring",
          "type": "\u003cinteger\u003e",
          "presence": "optional",
          "rangelist": [
            0,
            1
          ],
          "content": "If `true`, enables \"Wake for modem ring.\""
        },
        {
          "key": "Automatic Restart On Power Loss",
