{
  "category": "mdm/profiles",
  "name": "com.apple.cellular",
  "title": "Cellular",
  "description": "The payload that configures cellular settings.",
  "payload": {
    "payloadtype": "com.apple.cellular",
    "content": "This payload cannot be installed if an APN payload is already installed.\nThis payload only applies to the preferred data SIM. There is no way to have a cellular payload affect a different SIM.\nThis payload replaces the com.apple.managedCarrier payload. The latter payload is supported, but deprecated.",
    "supportedOS": {
      "iOS": {
        "introduced": "7.0"
      },
      "macOS": {
        "introduced": "n/a"
      },
      "tvOS": {
        "introduced": "n/a"
      },
      "visionOS": {
        "introduced": "n/a"
      },
      "watchOS": {
        "introduced": "3.2"
      }
    }
  },
