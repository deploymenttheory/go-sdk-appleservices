        "macOS": {
          "introduced": "n/a"
        },
        "visionOS": {
          "introduced": "n/a"
        }
      }
    },
    {
      "key": "AllowWhileLocked",
      "title": "Allow While Locked",
      "type": "\u003cboolean\u003e",
