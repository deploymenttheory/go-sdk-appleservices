# .gitattributes snippet to force users to use same line endings for project.
# 
# Handle line endings automatically for files detected as text
# and leave all files detected as binary untouched.
* text=auto

*.json text eol=lf
*.go text eol=lf
*.tmpl text eol=lf
*.mod text eol=lf
*.sum text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
